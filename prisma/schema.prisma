generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enable pgvector in migrations, but Prisma will manage it as Unsupported if needed
// Or we just store embeddings as Json or Unsupported("vector(1536)")

// --- CORE USER MODELS ---

model UserProfile {
  id            String            @id @default(uuid())
  userId        String            @unique // Maps to Supabase Auth User ID
  email         String            @unique
  password      String?
  fullName      String?
  avatarUrl     String?
  role          String            @default("user")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  
  conversations AIConversation[]
  goals         Goal[]
  healthRecords HealthRecord[]
  integrations  Integration[]
  reports       MedicalReport[]
  medications   Medication[]
  notifications Notification[]
  nutritionLogs Nutrition[]
  meals         Meal[]
  settings      Settings?
  sleepLogs     SleepLog[]
  symptoms      Symptom[]
  achievements  UserAchievement[]
  workouts      Workout[]
  preferences   UserPreference[]
  baselines     UserBaseline[]
  predictions   Prediction[]
  alerts        Alert[]
  timeline      TimelineEvent[]
  userMemory    UserMemory?
  searchHistory SearchHistory[]
}

model Settings {
  id               String      @id @default(uuid())
  profileId        String      @unique
  theme            String      @default("dark")
  notifications    Boolean     @default(true)
  language         String      @default("en")
  privacyShareData Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  profile          UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model UserPreference {
  id          String      @id @default(uuid())
  profileId   String
  category    String      
  value       String
  notes       String?
  createdAt   DateTime    @default(now())
  profile     UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// --- LONG TERM MEMORY ---
model UserMemory {
  id             String      @id @default(uuid())
  profileId      String      @unique
  dietPreference String?     // e.g. vegan, vegetarian, none
  allergies      String[]    // e.g. peanuts, dairy
  workoutPreference String?  // e.g. morning, evening
  sleepSchedule  String?     // e.g. 10pm-6am
  favoriteFoods  String[]
  units          String      @default("metric")
  fitnessGoals   String[]
  updatedAt      DateTime    @updatedAt
  profile        UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model SearchHistory {
  id          String      @id @default(uuid())
  profileId   String
  query       String
  category    String
  createdAt   DateTime    @default(now())
  profile     UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// --- HEALTH & FITNESS MODELS ---

model HealthRecord {
  id            String      @id @default(uuid())
  profileId     String
  vitalityScore Int         @default(100)
  stressLevel   Float?      
  recoveryScore Int?        
  heartRate     Int?
  hrv           Int?
  bloodPressure String?
  weight        Float?
  height        Float?
  bloodSugar    Float?
  oxygenLevel   Float?
  waterIntakeMl Int         @default(0)
  recordedAt    DateTime    @default(now())
  provider      String      @default("manual") 
  profile       UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model UserBaseline {
  id             String      @id @default(uuid())
  profileId      String
  metricName     String      
  value          Float
  windowDays     Int         @default(30)
  calculatedAt   DateTime    @default(now())
  profile        UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Workout {
  id             String      @id @default(uuid())
  profileId      String
  type           String
  duration       Int
  caloriesBurned Int
  intensity      String
  notes          String?
  recordedAt     DateTime    @default(now())
  profile        UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model SleepLog {
  id            String      @id @default(uuid())
  profileId     String
  durationHours Float
  deepSleepMin  Int
  remSleepMin   Int
  qualityScore  Int
  recordedAt    DateTime    @default(now())
  profile       UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// --- NUTRITION & FOOD MODELS ---

model Nutrition {
  id            String      @id @default(uuid())
  profileId     String
  mealType      String
  foodName      String
  calories      Int
  protein       Float
  carbs         Float
  fat           Float
  waterIntakeMl Int         @default(0)
  recordedAt    DateTime    @default(now())
  profile       UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Meal {
  id          String      @id @default(uuid())
  profileId   String
  name        String
  type        String      
  totalCals   Int
  totalProtein Float
  totalCarbs  Float
  totalFat    Float
  loggedAt    DateTime    @default(now())
  profile     UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  items       MealItem[]
}

model MealItem {
  id        String @id @default(uuid())
  mealId    String
  foodId    String
  amount    Float  
  unit      String 
  meal      Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)
  food      Food   @relation(fields: [foodId], references: [id], onDelete: Restrict)
}

model Food {
  id           String      @id @default(uuid())
  name         String
  aliases      String[]    
  category     String
  servingSize  Float
  servingUnit  String
  
  calories     Int
  protein      Float
  carbs        Float
  fat          Float
  fiber        Float
  sugar        Float
  
  sodium       Float?
  potassium    Float?
  calcium      Float?
  iron         Float?
  vitaminC     Float?
  vitaminD     Float?
  
  isVegetarian Boolean     @default(false)
  isVegan      Boolean     @default(false)
  isGlutenFree Boolean     @default(false)
  
  benefits     String[]
  risks        String[]
  
  createdAt    DateTime    @default(now())
  mealItems    MealItem[]
}

// --- AI & KNOWLEDGE MODELS ---

model AIConversation {
  id        String      @id @default(uuid())
  profileId String
  agentType String
  title     String      @default("New Conversation")
  createdAt DateTime    @default(now())
  profile   UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  messages  AIMessage[]
}

model AIMessage {
  id             String         @id @default(uuid())
  conversationId String
  role           String         
  content        String
  intent         String?        
  contextUsed    Json?          
  toolsUsed      String[]       
  latencyMs      Int?
  provider       String?        // Groq, etc
  model          String?
  createdAt      DateTime       @default(now())
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model VectorDocument {
  id          String   @id @default(uuid())
  title       String
  content     String
  category    String   
  metadata    Json?
  embedding   Json?    
  createdAt   DateTime @default(now())
}

// --- ENGINE OUTPUTS & INSIGHTS ---

model Prediction {
  id             String      @id @default(uuid())
  profileId      String
  metric         String
  predictedValue Float
  confidence     Int
  timeframeHours Int
  reasoning      String
  generatedAt    DateTime    @default(now())
  profile        UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Alert {
  id          String      @id @default(uuid())
  profileId   String
  title       String
  message     String
  severity    String      
  metricSource String
  isRead      Boolean     @default(false)
  createdAt   DateTime    @default(now())
  profile     UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model TimelineEvent {
  id          String      @id @default(uuid())
  profileId   String
  type        String      
  title       String
  description String
  timestamp   DateTime    @default(now())
  metadata    Json?
  profile     UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// --- MEDICAL & TRACKING ---

model Medication {
  id        String      @id @default(uuid())
  profileId String
  name      String
  dosage    String
  frequency String
  active    Boolean     @default(true)
  startDate DateTime    @default(now())
  endDate   DateTime?
  profile   UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Symptom {
  id         String      @id @default(uuid())
  profileId  String
  name       String
  severity   Int
  notes      String?
  recordedAt DateTime    @default(now())
  profile    UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model MedicalReport {
  id             String      @id @default(uuid())
  profileId      String
  fileName       String
  fileUrl        String
  summary        String?
  structuredData Json?
  analyzedAt     DateTime?
  createdAt      DateTime    @default(now())
  profile        UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Goal {
  id           String      @id @default(uuid())
  profileId    String
  category     String
  title        String
  targetValue  Float
  currentValue Float       @default(0)
  unit         String
  deadline     DateTime?
  completed    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  profile      UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model UserAchievement {
  id          String      @id @default(uuid())
  profileId   String
  title       String
  description String
  unlockedAt  DateTime    @default(now())
  profile     UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String      @id @default(uuid())
  profileId String
  title     String
  message   String
  read      Boolean     @default(false)
  type      String      @default("info")
  createdAt DateTime    @default(now())
  profile   UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Integration {
  id           String      @id @default(uuid())
  profileId    String
  provider     String
  accessToken  String
  refreshToken String?
  connected    Boolean     @default(true)
  lastSyncedAt DateTime    @default(now())
  profile      UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model ProviderSyncLog {
  id          String      @id @default(uuid())
  profileId   String
  provider    String      
  status      String      
  error       String?
  syncedAt    DateTime    @default(now())
}

model Otp {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
}