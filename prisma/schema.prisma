generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UserProfile {
  id            String            @id @default(uuid())
  userId        String            @unique
  email         String            @unique
  fullName      String?
  avatarUrl     String?
  role          String            @default("user")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  conversations AIConversation[]
  goals         Goal[]
  healthRecords HealthRecord[]
  integrations  Integration[]
  reports       MedicalReport[]
  medications   Medication[]
  notifications Notification[]
  nutrition     Nutrition[]
  settings      Settings?
  sleepLogs     SleepLog[]
  symptoms      Symptom[]
  achievements  UserAchievement[]
  workouts      Workout[]
}

model Settings {
  id               String      @id @default(uuid())
  profileId        String      @unique
  theme            String      @default("dark")
  notifications    Boolean     @default(true)
  language         String      @default("en")
  privacyShareData Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  profile          UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model HealthRecord {
  id            String      @id @default(uuid())
  profileId     String
  vitalityScore Int         @default(100)
  heartRate     Int?
  bloodPressure String?
  weight        Float?
  height        Float?
  bloodSugar    Float?
  oxygenLevel   Float?
  recordedAt    DateTime    @default(now())
  profile       UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Workout {
  id             String      @id @default(uuid())
  profileId      String
  type           String
  duration       Int
  caloriesBurned Int
  intensity      String
  notes          String?
  recordedAt     DateTime    @default(now())
  profile        UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Nutrition {
  id            String      @id @default(uuid())
  profileId     String
  mealType      String
  foodName      String
  calories      Int
  protein       Float
  carbs         Float
  fat           Float
  waterIntakeMl Int         @default(0)
  recordedAt    DateTime    @default(now())
  profile       UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model SleepLog {
  id            String      @id @default(uuid())
  profileId     String
  durationHours Float
  deepSleepMin  Int
  remSleepMin   Int
  qualityScore  Int
  recordedAt    DateTime    @default(now())
  profile       UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Medication {
  id        String      @id @default(uuid())
  profileId String
  name      String
  dosage    String
  frequency String
  active    Boolean     @default(true)
  startDate DateTime    @default(now())
  endDate   DateTime?
  profile   UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Symptom {
  id         String      @id @default(uuid())
  profileId  String
  name       String
  severity   Int
  notes      String?
  recordedAt DateTime    @default(now())
  profile    UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model MedicalReport {
  id             String      @id @default(uuid())
  profileId      String
  fileName       String
  fileUrl        String
  summary        String?
  structuredData Json?
  analyzedAt     DateTime?
  createdAt      DateTime    @default(now())
  profile        UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model AIConversation {
  id        String      @id @default(uuid())
  profileId String
  agentType String
  title     String      @default("New Conversation")
  createdAt DateTime    @default(now())
  profile   UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  messages  AIMessage[]
}

model AIMessage {
  id             String         @id @default(uuid())
  conversationId String
  sender         String
  content        String
  createdAt      DateTime       @default(now())
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Goal {
  id           String      @id @default(uuid())
  profileId    String
  category     String
  title        String
  targetValue  Float
  currentValue Float       @default(0)
  unit         String
  deadline     DateTime?
  completed    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  profile      UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model UserAchievement {
  id          String      @id @default(uuid())
  profileId   String
  title       String
  description String
  unlockedAt  DateTime    @default(now())
  profile     UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String      @id @default(uuid())
  profileId String
  title     String
  message   String
  read      Boolean     @default(false)
  type      String      @default("info")
  createdAt DateTime    @default(now())
  profile   UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Integration {
  id           String      @id @default(uuid())
  profileId    String
  provider     String
  accessToken  String
  refreshToken String?
  connected    Boolean     @default(true)
  lastSyncedAt DateTime    @default(now())
  profile      UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model profiles {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?   @db.Uuid
  bio        String?
  occupation String?
  language   String?
  theme      String?
  visibility String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String     @unique
  phone          String?
  full_name      String?
  username       String?    @unique
  avatar_url     String?
  dob            DateTime?  @db.Date
  gender         String?
  height_cm      Decimal?   @db.Decimal
  weight_kg      Decimal?   @db.Decimal
  blood_group    String?
  activity_level String?
  goal           String?
  country        String?
  timezone       String?
  created_at     DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?  @default(now()) @db.Timestamptz(6)
  profiles       profiles[]
}

model Otp {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
}